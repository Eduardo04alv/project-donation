@{
    ViewData["Title"] = "Admin Panel";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />

<div class="container mt-5">
    <div class="text-center">
        <h1 class="display-5 fw-bold">Welcome to the Admin Panel</h1>
        <p class="lead">From here, you can manage all donation system information.</p>
        <hr class="my-4" />
    </div>

    <div class="row justify-content-center g-4">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body text-center">
                    <h5 class="card-title fw-semibold">Manage Donors</h5>
                    <p class="card-text">View, add, edit and delete donors.</p>
                    <a asp-controller="Donors" asp-action="Index" class="btn btn-dark w-100">Go to Donor List</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body text-center">
                    <h5 class="card-title fw-semibold">Manage Beneficiaries</h5>
                    <p class="card-text">View, add, edit and delete beneficiaries.</p>
                    <a asp-controller="Beneficiaries" asp-action="Index" class="btn btn-dark w-100">Go to Beneficiary List</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body text-center">
                    <h5 class="card-title fw-semibold">Manage Donations</h5>
                    <p class="card-text">See donation history and details.</p>
                    <a asp-controller="Donations" asp-action="Index" class="btn btn-dark w-100">Go to Donation List</a>
                </div>
            </div>
        </div>
    </div>
</div>
