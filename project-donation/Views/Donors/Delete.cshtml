@model Donation_Domain.entities.Donor
@{
    ViewData["Title"] = "Delete Donor";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />

<div class="container mt-5">
    <h2 class="text-center mb-4 text-danger fw-bold">Are you sure you want to delete this donor?</h2>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="id_donor" />

        <div class="row mb-4">           
            <div class="col-md-8">
                <div class="form-group mb-3">
                    <label asp-for="name_donor" class="form-label">Name</label>
                    <input asp-for="name_donor" class="form-control" readonly />
                </div>

                <div class="form-group mb-3">
                    <label asp-for="email_donor" class="form-label">Email</label>
                    <input asp-for="email_donor" class="form-control" readonly />
                </div>

                <div class="form-group mb-3">
                    <label asp-for="phone_donor" class="form-label">Phone</label>
                    <input asp-for="phone_donor" class="form-control" readonly />
                </div>
            </div>
        </div>

        <div class="text-center">
            <input type="submit" value="Delete" class="btn btn-danger me-3 px-4" />
            <a asp-action="Index" class="btn btn-secondary px-4">Cancel</a>
        </div>
    </form>

    <div class="mt-4 text-center">
        <a asp-action="Index">← Back to list</a>
    </div>
</div>