@model Donation_Domain.entities.Donor
@{
    ViewData["Title"] = "Add Donor";
}
<div class="container mt-5">
    <h2 class="text-center mb-4 fw-bold">Add a New Donor</h2>

    <form asp-controller="Donors" asp-action="Create" method="post" enctype="multipart/form-data">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row">
            <div class="form-group col-md-4 mb-3">
                <label asp-for="name_donor" class="form-label"></label>
                <input asp-for="name_donor" class="form-control" required />
                <span asp-validation-for="name_donor" class="text-danger"></span>
            </div>

            <div class="form-group col-md-4 mb-3">
                <label asp-for="email_donor" class="form-label"></label>
                <input asp-for="email_donor" type="email" class="form-control" required />
                <span asp-validation-for="email_donor" class="text-danger"></span>
            </div>

            <div class="form-group col-md-4 mb-3">
                <label asp-for="phone_donor" class="form-label"></label>
                <input asp-for="phone_donor" type="tel" class="form-control" required />
                <span asp-validation-for="phone_donor" class="text-danger"></span>
            </div>
        </div>
        <div class="text-center">
            <button type="submit" class="btn btn-primary px-4">
                <i class="bi bi-save2-fill"></i> Save
            </button>
        </div>
    </form>
</div>