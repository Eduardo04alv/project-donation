@model Donation_Domain.entities.Beneficiarie
@{
    ViewData["Title"] = "Add Beneficiary";
}
<div class="container mt-5">
    <h2 class="text-center mb-4 fw-bold">Add a New Beneficiary</h2>

    <form asp-controller="Beneficiaries" asp-action="Create" method="post" enctype="multipart/form-data">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row">
            <div class="form-group col-md-4 mb-3">
                <label asp-for="name_Benefi" class="form-label"></label>
                <input asp-for="name_Benefi" class="form-control" required />
                <span asp-validation-for="name_Benefi" class="text-danger"></span>
            </div>

            <div class="form-group col-md-4 mb-3">
                <label asp-for="phone_Benefi" class="form-label"></label>
                <input asp-for="phone_Benefi" type="tel" class="form-control" required />
                <span asp-validation-for="phone_Benefi" class="text-danger"></span>
            </div>

            <div class="form-group col-md-4 mb-3">
                <label asp-for="website" class="form-label"></label>
                <input asp-for="website" class="form-control" />
                <span asp-validation-for="website" class="text-danger"></span>
            </div>

            <div class="form-group col-md-12 mb-4">
                <label asp-for="description" class="form-label"></label>
                <textarea asp-for="description" class="form-control"></textarea>
                <span asp-validation-for="description" class="text-danger"></span>
            </div>
        </div>
        <div class="text-center">
            <button type="submit" class="btn btn-primary px-4">
                <i class="bi bi-save2-fill"></i> Save
            </button>
            <a asp-action="Index" class="btn btn-secondary ms-2">
                <i class="bi bi-x-circle-fill"></i> Cancel
            </a>
        </div>
    </form>
</div>