@model Donation_Domain.entities.Beneficiarie
@{
    ViewData["Title"] = "Delete Beneficiary";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />

<div class="container mt-5">
    <h2 class="text-center mb-4 text-danger fw-bold">Are you sure you want to delete this beneficiary?</h2>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="id_Benefi" />

        <div class="row mb-4">
            <div class="col-md-6">
                <div class="form-group mb-3">
                    <label asp-for="name_Benefi" class="form-label fw-semibold">Name</label>
                    <input asp-for="name_Benefi" class="form-control" readonly />
                </div>

                <div class="form-group mb-3">
                    <label asp-for="phone_Benefi" class="form-label fw-semibold">Phone</label>
                    <input asp-for="phone_Benefi" class="form-control" readonly />
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group mb-3">
                    <label asp-for="website" class="form-label fw-semibold">Website</label>
                    <input asp-for="website" class="form-control" readonly />
                </div>

                <div class="form-group mb-3">
                    <label asp-for="description" class="form-label fw-semibold">Description</label>
                    <textarea asp-for="description" class="form-control" readonly></textarea>
                </div>
            </div>
        </div>

        <div class="text-center">
            <input type="submit" value="Delete" class="btn btn-danger me-3 px-4" />
            <a asp-action="Index" class="btn btn-secondary px-4">Cancel</a>
        </div>
    </form>

    <div class="mt-4 text-center">
        <a asp-action="Index">← Back to list</a>
    </div>
</div>