@model Donation_Domain.entities.Beneficiarie
@{
    ViewData["Title"] = "Update Beneficiary";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />

<div class="container mt-5">
    <h2 class="text-center mb-4 fw-bold">Update Beneficiary</h2>

    <form asp-action="Update" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="id_Benefi" />

        <div class="row mb-4">
            <div class="col-md-6">
                <div class="form-group mb-3">
                    <label asp-for="name_Benefi" class="form-label fw-semibold">Name</label>
                    <input asp-for="name_Benefi" class="form-control" />
                    <span asp-validation-for="name_Benefi" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="phone_Benefi" class="form-label fw-semibold">Phone</label>
                    <input asp-for="phone_Benefi" class="form-control" />
                    <span asp-validation-for="phone_Benefi" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group mb-3">
                    <label asp-for="website" class="form-label fw-semibold">Website</label>
                    <input asp-for="website" class="form-control" />
                    <span asp-validation-for="website" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="description" class="form-label fw-semibold">Description</label>
                    <textarea asp-for="description" class="form-control"></textarea>
                    <span asp-validation-for="description" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="text-center">
            <button type="submit" class="btn btn-success px-4">
                <i class="bi bi-save2-fill"></i> Save Changes
            </button>
            <a asp-action="Index" class="btn btn-secondary ms-2 px-4">
                <i class="bi bi-x-circle-fill"></i> Cancel
            </a>
        </div>
    </form>

    <div class="mt-4 text-center">
        <a asp-action="Index">← Back to list</a>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}