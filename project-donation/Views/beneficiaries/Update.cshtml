@model Donation_Domain.entities.Beneficiarie
@{
    ViewData["Title"] = "Update Beneficiary";
}

<form asp-action="Update">
    <input type="hidden" asp-for="id_Benefi" />

    <div class="form-group">
        <label asp-for="name_Benefi" class="control-label">Nombre</label>
        <input asp-for="name_Benefi" class="form-control" />
        <span asp-validation-for="name_Benefi" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="phone_Benefi" class="control-label">Teléfono</label>
        <input asp-for="phone_Benefi" class="form-control" />
        <span asp-validation-for="phone_Benefi" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="website" class="control-label">Sitio Web</label>
        <input asp-for="website" class="form-control" />
        <span asp-validation-for="website" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="description" class="control-label">Descripción</label>
        <textarea asp-for="description" class="form-control"></textarea>
        <span asp-validation-for="description" class="text-danger"></span>
    </div>
    <h4></h4>
    <div class="form-group">
        <input type="submit" value="Guardar" class="btn btn-primary" />
    </div>
</form>
<h4></h4>
<div>
    <a asp-action="Index">Volver a la lista</a>
</div>
    <a asp-action="Index">Back to list</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}