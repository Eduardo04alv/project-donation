@model project_donation.Models.donations.Donations
@{
    ViewData["Title"] = "Delete Donation";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />

<div class="container mt-5">
    <h2 class="text-center mb-4 text-danger fw-bold">Are you sure you want to delete this donation?</h2>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="d_donation" />

        <div class="row mb-4">
            <div class="col-md-6">
                <div class="form-group mb-3">
                    <label asp-for="id_donor" class="form-label fw-semibold">Donor ID</label>
                    <input asp-for="id_donor" class="form-control" readonly />
                </div>

                <div class="form-group mb-3">
                    <label asp-for="id_Benefi" class="form-label fw-semibold">Beneficiary ID</label>
                    <input asp-for="id_Benefi" class="form-control" readonly />
                </div>

                <div class="form-group mb-3">
                    <label asp-for="amount" class="form-label fw-semibold">Amount</label>
                    <input asp-for="amount" class="form-control" readonly />
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group mb-3">
                    <label asp-for="type_donation" class="form-label fw-semibold">Type</label>
                    <input asp-for="type_donation" class="form-control" readonly />
                </div>

                <div class="form-group mb-3">
                    <label asp-for="date_donation" class="form-label fw-semibold">Date</label>
                    <input asp-for="date_donation" class="form-control" readonly />
                </div>
            </div>
        </div>

        <div class="text-center">
            <input type="submit" value="Delete" class="btn btn-danger me-3 px-4" />
            <a asp-action="Index" class="btn btn-secondary px-4">Cancel</a>
        </div>
    </form>

    <div class="mt-4 text-center">
        <a asp-action="Index">← Back to list</a>
    </div>
</div>
<div class="position-fixed top-0 end-0 p-3 z-3">
    <div class="btn-group" role="group" aria-label="Admin Navigation">
        <a asp-controller="Donors" asp-action="Index" class="btn btn-outline-primary">Donors</a>
        <a asp-controller="Beneficiaries" asp-action="Index" class="btn btn-outline-success">Beneficiaries</a>
        <a asp-controller="Donations" asp-action="Index" class="btn btn-outline-danger">Donations</a>
    </div>
</div>