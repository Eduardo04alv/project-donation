@model project_donation.Models.donations.Donations

@{
    ViewData["Title"] = "Update Donation";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />

<div class="container mt-5">
    <h2 class="text-center mb-4">Update Donation</h2>

    <form asp-action="Update" method="post">
        <input type="hidden" asp-for="d_donation" />

        <div class="row mb-4">
            <div class="col-md-8 mx-auto">
                <div class="form-group mb-3">
                    <label asp-for="id_donor" class="form-label">Donor ID</label>
                    <input asp-for="id_donor" class="form-control" />
                    <span asp-validation-for="id_donor" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="id_Benefi" class="form-label">Beneficiary ID</label>
                    <input asp-for="id_Benefi" class="form-control" />
                    <span asp-validation-for="id_Benefi" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="amount" class="form-label">Amount</label>
                    <input asp-for="amount" class="form-control" />
                    <span asp-validation-for="amount" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="type_donation" class="form-label">Type</label>
                    <input asp-for="type_donation" class="form-control" />
                    <span asp-validation-for="type_donation" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="date_donation" class="form-label">Date</label>
                    <input asp-for="date_donation" type="date" class="form-control" />
                    <span asp-validation-for="date_donation" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="text-center">
            <input type="submit" value="Save Changes" class="btn btn-success px-4" />
            <a asp-action="Index" class="btn btn-secondary ms-2 px-4">Cancel</a>
        </div>
    </form>

    <div class="mt-4 text-center">
        <a asp-action="Index">← Back to list</a>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
