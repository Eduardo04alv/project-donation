@model project_donation.Models.donations.Donations

@{
    ViewData["Title"] = "Add Donation";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />

<div class="container mt-5">
    <h2 class="text-center mb-4 fw-bold">Add a New Donation</h2>

    <form asp-controller="Donations" asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row">
            <div class="form-group col-md-4 mb-3">
                <label asp-for="id_donor" class="form-label">Donor</label>
                <select asp-for="id_donor" class="form-select" asp-items="ViewBag.Donors">
                    <option value="">-- Select Donor --</option>
                </select>
                <span asp-validation-for="id_donor" class="text-danger"></span>
            </div>

            <div class="form-group col-md-4 mb-3">
                <label asp-for="id_Benefi" class="form-label">Beneficiary</label>
                <select asp-for="id_Benefi" class="form-select" asp-items="ViewBag.Beneficiaries">
                    <option value="">-- Select Beneficiary --</option>
                </select>
                <span asp-validation-for="id_Benefi" class="text-danger"></span>
            </div>

            <div class="form-group col-md-4 mb-3">
                <label asp-for="amount" class="form-label">Amount</label>
                <input asp-for="amount" class="form-control" required />
                <span asp-validation-for="amount" class="text-danger"></span>
            </div>

            <div class="form-group col-md-4 mb-3">
                <label asp-for="type_donation" class="form-label">Type</label>
                <input asp-for="type_donation" class="form-control" required />
                <span asp-validation-for="type_donation" class="text-danger"></span>
            </div>

            <div class="form-group col-md-4 mb-3">
                <label asp-for="date_donation" class="form-label">Date</label>
                <input asp-for="date_donation" type="date" class="form-control" />
                <span asp-validation-for="date_donation" class="text-danger"></span>
            </div>
        </div>

        <div class="text-center">
            <button type="submit" class="btn btn-primary px-4">
                <i class="bi bi-save2-fill"></i> Save
            </button>
            <a asp-action="Index" class="btn btn-secondary ms-2">
                <i class="bi bi-x-circle-fill"></i> Cancel
            </a>
        </div>
    </form>
</div>
