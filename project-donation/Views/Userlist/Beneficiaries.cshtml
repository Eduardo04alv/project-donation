@model List<Donation_Domain.entities.Beneficiarie>
@{
    ViewData["Title"] = "Beneficiaries";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />

<div class="container mt-5">
    <h2 class="text-center mb-4 fw-bold">Beneficiary List</h2>

   

    <table class="table table-hover table-bordered text-center align-middle">
        <thead class="table-dark">
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Phone</th>
                <th>Website</th>
                <th>Description</th>
               
            </tr>
        </thead>
        <tbody>
            @if (Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.id_Benefi</td>
                        <td>@item.name_Benefi</td>
                        <td>@item.phone_Benefi</td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.website))
                            {
                                <a href="@item.website" target="_blank" rel="noopener noreferrer">@item.website</a>
                            }
                            else
                            {
                                <span class="text-muted">Not available</span>
                            }
                        </td>
                        <td>@item.description</td>
                      
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center">No records found</td>
                </tr>
            }
        </tbody>
    </table>
</div>
<div class="position-fixed top-0 end-0 p-3 z-3">
    <div class="btn-group" role="group" aria-label="Admin Navigation">
        <a asp-controller="Userlist" asp-action="Donor" class="btn btn-outline-primary">Donors</a>
        <a asp-controller="Userlist" asp-action="Beneficiaries" class="btn btn-outline-success">Beneficiaries</a>
        <a asp-controller="Userlist" asp-action="Donations" class="btn btn-outline-danger">Donations</a>
    </div>
</div>
